# swarm-code — terminal coding agent built in sw on the swarmrt runtime

SWARMRT ?= ../swarmrt
SWC     := $(SWARMRT)/bin/swc

SRC_DIR := src
BIN     := bin/swarm-code

# All .sw files — let make rebuild on any change. Easier than
# maintaining this list by hand every time we add a module.
SOURCES := $(wildcard $(SRC_DIR)/*.sw)

# Version comes from the VERSION file at the repo root (single line,
# e.g. 0.4.0) — not `git describe`, so tarball builds without .git and
# pre-tag branches still report the right version. Release tags in
# .github/workflows/release.yml should match VERSION.
VERSION_STR := $(shell cat VERSION 2>/dev/null || echo 0.0.0-dev)

TESTBIN := bin/swarm-code-test

.PHONY: all clean run test smoke integration

all: $(BIN)

# src/Version.sw is generated from VERSION on every build (FORCE), but
# only rewritten when the content actually changes — an unchanged
# VERSION never bumps the mtime, so it never dirties rebuilds.
FORCE:
$(SRC_DIR)/Version.sw: VERSION FORCE
	@printf 'module Version\n\n# AUTO-GENERATED by make from the VERSION file at the repo root — do not edit.\nfun version() { "%s" }\n' "$(VERSION_STR)" > $@.tmp; \
	if cmp -s $@.tmp $@; then rm $@.tmp; else mv $@.tmp $@; fi

$(BIN): $(SRC_DIR)/Version.sw $(SOURCES)
	@mkdir -p bin
	$(SWC) build $(SRC_DIR)/main.sw -o $(BIN)
	@echo "swarm-code: built $(BIN)"

# Test suite — builds and runs bin/swarm-code-test. Exits non-zero
# if any check fails, so `make test` works in CI / pre-commit.
test: $(TESTBIN)
	@./$(TESTBIN)

$(TESTBIN): $(SRC_DIR)/Version.sw $(SOURCES)
	@mkdir -p bin
	@$(SWC) build $(SRC_DIR)/test_runner.sw -o $(TESTBIN)

clean:
	rm -rf bin

run: $(BIN)
	./$(BIN)

# Smoke test — boots the binary in headless mode, runs one bash tool call,
# verifies the response. Used by tests/smoke.sh.
smoke: $(BIN)
	@BIN=./$(BIN) ./tests/smoke.sh

# Integration (E2E) suite — runs the real binary headless against a
# scripted mock LLM endpoint (tests/integration/). Isolated $HOME per
# test; needs only python3 + curl. See tests/integration/run.sh.
integration: $(BIN)
	@BIN=./$(BIN) ./tests/integration/run.sh

# Run the per-module tests in tests/ (8 modules; the main 84-check
# regression suite runs via `make test`).
test-all:
	@./tests/run_all.sh

# Handy one-liner for ad hoc testing against a local endpoint.
run-local: $(BIN)
	SWARM_CODE_ENDPOINT=http://localhost:8000 ./$(BIN)
