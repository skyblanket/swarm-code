# Allowlist mode: this directory accumulated unrelated research
# artifacts over time, so we ignore everything at root by default
# and explicitly opt in the swarm-code project files.
/*
!/.gitignore
!/.github/
!/Makefile
!/README.md
!/LICENSE
!/CHANGELOG.md
!/AUDIT.md
!/REVIEW.md
!/CONTRIBUTING.md
!/scripts/
!/src/
!/docs/
!/tests/

# Inside scripts/, only install.* belongs to swarm-code; the rest is
# noise from earlier sessions and stays untracked.
scripts/*
!scripts/install.sh
!scripts/install.ps1

# Inside src/, ignore generated C output from `swc build`.
src/*.gen.c
src/*.gen.h

# Editor / OS noise (anywhere)
.DS_Store
*.swp
