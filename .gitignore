# Allowlist mode: this directory accumulated unrelated research
# artifacts over time, so we ignore everything at root by default
# and explicitly opt in the swarm-code project files.
/*
!/.gitignore
!/.github/
!/Makefile
!/README.md
!/LICENSE
!/CHANGELOG.md
!/CONTRIBUTING.md
!/SECURITY.md
!/scripts/
!/src/
!/docs/
!/tests/
!/VERSION

# Inside scripts/, only install.* belongs to swarm-code; the rest is
# noise from earlier sessions and stays untracked.
scripts/*
!scripts/install.sh
!scripts/install.ps1
!scripts/council.sh

# Inside src/, ignore generated C output from `swc build` and the
# version module make generates from the VERSION file.
src/*.gen.c
src/*.gen.h
src/Version.sw

# Editor / OS noise (anywhere)
.DS_Store
*.swp
